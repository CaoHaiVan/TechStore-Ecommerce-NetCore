@model ContactModel
<div class="row">

	<div class="col-sm-5 col-md-5">
		@Html.Raw(@Model.Map)
		@Html.Raw(@Model.Description)
	</div>

	<div class="col-sm-4">
		<div class="address">
			<h5>Name: @Model.Name</h5>
			<h5>Email: @Model.Email</h5>
			<h5>@Model.Phone</h5>

			<!-- Facebook Page Plugin -->
			<div class="fb-page"
				 data-href="https://www.facebook.com/profile.php?id=61564531051592"
				 data-tabs="message"
				 data-width="600"
				 data-height="500"
				 data-small-header="false"
				 data-adapt-container-width="true"
				 data-hide-cover="false"
				 data-show-facepile="true">
				<blockquote cite="https://www.facebook.com/profile.php?id=61564531051592" class="fb-xfbml-parse-ignore">
					<a href="https://www.facebook.com/profile.php?id=61564531051592">Học Hỏi Thêm Về Công Nghệ</a>
				</blockquote>
			</div>
		</div>
	</div>
</div>
