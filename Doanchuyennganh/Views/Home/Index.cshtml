@model IEnumerable<ProductModel>
@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/Shared/_Layout.cshtml";
}
<partial name="_SliderPartial"/>
<div class="col-sm-3">
	<partial name="_SidebarPartial"/>
</div>
<style>
	.product-image-warpper {
		height: 450px;
	}
</style>
<div class="col-sm-9 padding-right">
	<div class="features_items">
		<!--features_items-->
		<h2 class="title text-center">Features Items</h2>
		@foreach(var item in Model){
		<div class="col-sm-4">
			<div class="product-image-wrapper">
			
				<div class="single-products">
					
					<div class="productinfo text-center">
						<a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id">
						<img src="~/media/products/@item.Image" alt="@item.Name" width="100%" />
								<h2>@item.Price.ToString("#,##0 VNĐ")</h2>
							<p>@item.Name</p>
							<p>Danh mục : @item.Category.Name</p>
							<p>Thương hiệu : @item.Brand.Name</p>
						</a>
							@* <a class="btn btn-default add-to-cart" asp-action="Add" asp-controller="Cart" asp-route-Id="@item.Id"><i class="fa fa-shopping-cart">< /i>Thêm giỏ hàng</a>*@
							@if (item.Quantity > 0)
							{
								<button class="btn btn-default add-to-cart" data-product_id="@item.Id"><i class="fa fa-shopping-cart"></i>Thêm giỏ hàng</button>
							}
							else
							{
								<button class="btn btn-default"> <i class="fa fa-shopping-cart"></i> Hết hàng</button>

							}
						</div>
					
				</div>
				<div class="choose">
						@if (User.Identity?.IsAuthenticated ?? false)
						{
							<ul class="nav nav-pills" style="display:flex; justify-content:center; gap:10px; list-style:none; padding:0;">
								<li><button class="btn btn-warning add-btn-wishlist" data-product_id="@item.Id">Yêu thích</button></li>
								<li><button class="btn btn-danger add-btn-compare" data-product_id="@item.Id">So sánh</button></li>
							</ul>

						}
					</div>
			</div>
		</div>
	}
	

	</div><!--features_items-->

	<!-- PHÂN TRANG -->
	<nav aria-label="Page navigation" class="text-center mt-5">
		<ul class="pagination justify-content-center">
			@if (ViewBag.TotalPages > 1)
			{
				for (int i = 1; i <= ViewBag.TotalPages; i++)
				{
					<li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
						<a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
					</li>
				}
			}
		</ul>
	</nav>

	<style>
		.pagination .page-item.active .page-link {
			background-color: #FE980F;
			border-color: #FE980F;
			color: white;
		}

		.pagination .page-link {
			color: #FE980F;
		}
	</style>

</div>
@section Scripts {
	<script>
		$(document).ready(function () {
			$('.add-to-cart').click(function () {
				var Id = $(this).data("product_id");

				//alert(product_id);

				$.ajax({
					type: "POST",
					url: "@Url.Action("Add","Cart")",
					data: { Id: Id }, // send data to the server

					success: function (result) {
						//handle successful update
						if (result) {
							Swal.fire("Thêm vào giỏ hàng thành công.")
						}
					}
				});
			});
		});
	</script>
	<!--Add to wishlist script-->
	<script>
		$(document).ready(function () {
			$('.add-btn-wishlist').click(function () {
				var Id = $(this).data("product_id");

				//alert(product_id);

				$.ajax({
					type: "POST",
					url: "@Url.Action("AddWishlist","Home")",
					data: { Id: Id }, // send data to the server

					success: function (result) {
						//handle successful update
						if (result) {
							Swal.fire("Thêm yêu thích sản phẩm thành công.")
						}
					}
				});
			});
		});
	</script>
	<!--//Add to wishlist script-->


	<!--Add to compare script-->
	<script>
		$(document).ready(function () {
			$('.add-btn-compare').click(function () {
				var Id = $(this).data("product_id");

				//alert(product_id);

				$.ajax({
					type: "POST",
					url: "@Url.Action("AddCompare","Home")",
					data: { Id: Id }, // send data to the server

					success: function (result) {
						//handle successful update
						if (result) {
							Swal.fire("Thêm so sánh sản phẩm thành công.")
						}
					}
				});
			});
		});
	</script>
	<!--//Add to compare script-->
}