@{
    ViewData["Title"] = "VAN-Shopper";
}

<section style="background-color:#fafafa;padding:60px 0;text-align:center;">
    <div style="max-width:1000px;margin:0 auto;">
        <h2 style="color:#FE980F;font-size:36px;font-weight:700;margin-bottom:20px;">
            Chào mừng đến với VAN-SHOPPER
        </h2>

        <p style="font-size:17px;color:#555;line-height:1.7;margin-bottom:30px;">
            VAN-SHOPPER mang đến cho bạn những sản phẩm điện tử, phụ kiện và thiết bị công nghệ
            với chất lượng đảm bảo và giá thành hợp lý. Chúng tôi luôn nỗ lực mang đến trải nghiệm
            mua sắm tiện lợi, nhanh chóng và đáng tin cậy cho mọi khách hàng.
        </p>

        <p>
            <img src="~/media/logo/f83a5717-bc49-4efa-95d0-a561d0d87111_logo1.jpg"
                 alt="Logo VAN-SHOPPER"
                 width="180" height="120"
                 style="border-radius:10px;box-shadow:0 0 10px rgba(0,0,0,0.15);" />
        </p>

        <ul style="list-style:none;padding:0;margin:30px auto;text-align:left;display:inline-block;">
            <li style="font-size:16px;color:#444;margin-bottom:10px;">✅ Sản phẩm chính hãng, bảo hành uy tín</li>
            <li style="font-size:16px;color:#444;margin-bottom:10px;">🚚 Giao hàng nhanh, phí vận chuyển thấp</li>
            <li style="font-size:16px;color:#444;margin-bottom:10px;">💬 Hỗ trợ khách hàng 24/7</li>
        </ul>

        <a href="/Home/Contact"
           style="display:inline-block;background-color:#FE980F;color:white;padding:12px 25px;
                  border-radius:5px;text-decoration:none;font-weight:600;transition:0.3s;">
            Liên hệ ngay
        </a>
    </div>
</section>
