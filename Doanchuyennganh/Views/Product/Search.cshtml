@model IEnumerable<ProductModel>
@{
    ViewData["Title"] = @ViewBag.Keyword;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="col-sm-3">
    <partial name="_SidebarPartial" />
</div>

<style>
    .product-image-wrapper {
        height: 450px;
    }
</style>

<div class="col-sm-9 padding-right">
    <div class="features_items">
        <h2 class="title text-center">@ViewBag.Slug</h2>

        @foreach (var item in Model)
        {
            <div class="col-sm-4">
                <div class="product-image-wrapper">
                    <div class="single-products">
                        <div class="productinfo text-center">

                            <!-- LINK XEM CHI TIẾT -->
                            <a asp-action="Details" asp-controller="Product" asp-route-Id="@item.Id">
                                <img src="~/media/products/@item.Image" alt="@item.Name" width="100%" />
                                <h2>@item.Price.ToString("#,##0 VNĐ")</h2>
                                <p>@item.Name</p>
                                <p>Danh mục: @item.Category.Name</p>
                                <p>Thương hiệu: @item.Brand.Name</p>
                            </a>

                            <!-- NÚT THÊM GIỎ HÀNG -->
                            @if (item.Quantity > 0)
                            {
                                <button class="btn btn-default add-to-cart" data-product_id="@item.Id"><i class="fa fa-shopping-cart"></i>Thêm giỏ hàng</button>
                            }
                            else
                            {
                                <button class="btn btn-default"><i class="fa fa-shopping-cart"></i>Hết hàng</button>
                            }

                        </div>
                    </div>

                    <!-- NÚT YÊU THÍCH / SO SÁNH -->
                    <div class="choose">
                        <ul class="nav nav-pills" style="display:flex; justify-content:center; gap:10px; list-style:none; padding:0;">
                            <li><button class="btn btn-warning add-btn-wishlist" data-product_id="@item.Id">Yêu thích</button></li>
                            <li><button class="btn btn-danger add-btn-compare" data-product_id="@item.Id">So sánh</button></li>
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@section Scripts {
    <!-- Add to cart -->
    <script>
        $(document).ready(function () {
            $('.add-to-cart').click(function () {
                var Id = $(this).data("product_id");
                $.ajax({
                    type: "POST",
                    url: "@Url.Action("Add", "Cart")",
                    data: { Id: Id },
                    success: function (result) {
                        if (result) {
                            Swal.fire("Thêm vào giỏ hàng thành công.")
                        }
                    }
                });
            });
        });
    </script>

    <!-- Add to wishlist -->
    <script>
        $(document).ready(function () {
            $('.add-btn-wishlist').click(function () {
                var Id = $(this).data("product_id");
                $.ajax({
                    type: "POST",
                    url: "@Url.Action("AddWishlist", "Home")",
                    data: { Id: Id },
                    success: function (result) {
                        if (result) {
                            Swal.fire("Thêm yêu thích sản phẩm thành công.")
                        }
                    }
                });
            });
        });
    </script>

    <!-- Add to compare -->
    <script>
        $(document).ready(function () {
            $('.add-btn-compare').click(function () {
                var Id = $(this).data("product_id");
                $.ajax({
                    type: "POST",
                    url: "@Url.Action("AddCompare", "Home")",
                    data: { Id: Id },
                    success: function (result) {
                        if (result) {
                            Swal.fire("Thêm so sánh sản phẩm thành công.")
                        }
                    }
                });
            });
        });
    </script>
}
