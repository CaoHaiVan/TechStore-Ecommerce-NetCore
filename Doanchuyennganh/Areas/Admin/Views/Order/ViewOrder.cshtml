@model IEnumerable<OderDetails>
@{
    ViewData["title"] = "Order Details";
    decimal total = 0; // store total amount
    decimal subtotal = 0;
}
<DOCTYPE html>
    <html>
        <head>
            <meta name="viewport" content="width=device-width"/>
            <title>Oder Details</title>
        </head>
        <body>
        <h3>List Order</h3>


    <table class="table" id="detail_order">
    <thead>
        <tr>
            <th scope="col">#</th>
            <th scope="col">Order Code</th>
            <th scope="col">UserName</th>
            <th scope="col">Product Name</th>
            <th scope="col">Product Price</th>
            <th scope="col">Quantity</th>
            <th scope="col">Subtotal</th>

        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
             subtotal = item.Quantity * item.Price;
             total += subtotal;
            <tr>
                <input type="hidden" asp-for="@item.OrderCode" class="getId"/>
                <td>@item.Id</td>
                <td>@item.OrderCode</td>
                <td>@item.UserName</td>
                <td>@item.Product.Name</td>
                <td>@item.Price.ToString("#,##0 VNĐ")</td>
                <td>@item.Quantity</td>
                <td>@subtotal.ToString("#,##0 VNĐ")</td>
             </tr>
             }
             <tr>
                 <th>Total:</th>
                 <td></td>
                 <td></td>
                 <td></td>
                 <td></td>
                 <td>@total.ToString("#,##0 VNĐ")</td>
                    <td>Shipping cost: @ViewBag.ShippingCost.ToString("#,##0 VNĐ")</td>
                 <td>
                        @if (ViewBag.Status != 3)
                        {
                            <select class="form-control select-update-order">
                                <option value="1" selected="@((int)ViewBag.Status == 1)">Đơn hàng mới</option>
                                <option value="2" selected="@((int)ViewBag.Status == 2)">Đã xử lý</option>
                                <option value="3" selected="@((int)ViewBag.Status == 3)">Đã hủy</option>
                            </select>

                        }
                 </td>
             </tr>    
    </tbody>
</table>
 </body>
</html>
@section Scripts{
    <script>
        new DataTable('#detail_order', {
            layout: {
                topStart: {
                    buttons: ['pdf','print']
                }
            }
        });
    </script>
    <script>
        $(document).ready(function () {
            $('.select-update-order').change(function () {
                var status = $(this).val();
                var ordercode = $('.getId').val();
                // alert(status);
                // alert(ordercode);

                $.ajax({
                    type: "POST",
                    url: "@Url.Action("UpdateOrder")",
                            data: { status: status, ordercode: ordercode }, //send data to the server

                    success: function (result) {
                        //Handle successful update
                        if (result.success) {
                            Swal.fire("Cập nhật đơn hàng thành công.");
                        }
                        else {
                            //handle error
                            Swal.fire("Cập nhật đơn hàng thất bại." + result.message);

                        }
                    }
                   
                });
            });
        });
    </script>
}


