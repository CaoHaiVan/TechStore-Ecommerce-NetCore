@model IEnumerable<ProductModel>
@{
    ViewData["title"] = "Product Listed";
}
<h3>List Products</h3>
<a asp-action="Create" asp-controller="Product" class="btn btn-primary">Add Product</a>
<table class="table" id="myTable">
    <thead>
        <tr>
            <th>Id</th>
            <th>Product Name</th>
            <th>Product Quantity</th>
            <th>Product Sold</th>
          @*   <th>Product Description</th> *@
            <th>Product Price</th>
            <th>Product Capital Price</th>
            <th>Product Image</th>
           @*  <th>Product Slug</th> *@
            <th>Product Category</th>
            <th>Product Brand</th>
            <th>Action</th>

        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            <tr>
                <th scope="row">@item.Id</th>
                <td>@item.Name</td>
                <td><b>@item.Quantity</b><br/><a asp-controller="Product" asp-action="AddQuantity" asp-route-Id="@item.Id">Add Quantity</a></td>
                <td><b>@item.Sold</b></td>
              @*   <td>@Html.Raw(item.Description)</td> *@
                <td>@item.Price.ToString("#,##0 VNĐ")</td>
                <td>@item.CapitalPrice.ToString("#,##0 VNĐ")</td>
                <td><img src="~/media/products/@item.Image" width="120px" height="150px"/></td>
                @* <td>@item.Slug</td> *@
                <td>@item.Category.Name</td>
                <td>@item.Brand.Name</td>
                <td>
                    <a asp-action="Edit" class="btn btn-warning btn-sm" asp-controller="Product" asp-route-Id="@item.Id">Edit</a>
                    <a asp-action="Delete" class="btn btn-danger btn-sm confirmDeletion" asp-controller="Product" asp-route-Id="@item.Id">Delete</a>


                </td>
            </tr>
        }
       
    </tbody>
</table>
